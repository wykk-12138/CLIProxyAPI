"type":"object","properties":{"limit":{"description":"Maximum number of hotspots to return (default: 10)","type":"number"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_impact","description":"Compute the impact radius of a node: all symbols that directly or indirectly depend on it.","input_schema":{"type":"object","properties":{"max_depth":{"description":"Maximum traversal depth (default: 3)","type":"number"},"node_id":{"description":"The unique node ID to compute impact for","type":"string"}},"required":["node_id"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_implementations","description":"Find every type implementing a given trait, or every body of a given method name. The 'trait' form returns each implementing type plus the methods on its impl block. The 'method' form returns every function/ method named X across the project, grouped by enclosing type when present. Each result includes file, signature, and the method body.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of implementations to return (default: 20, max: 200)","type":"number"},"method":{"description":"Method or function name to find every implementation of (e.g. 'extensions', 'count_complexity'). Mutually exclusive with 'trait'.","type":"string"},"trait":{"description":"Trait name to look up implementations of (e.g. 'LanguageExtractor', 'Display'). Mutually exclusive with 'method'.","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_impls","description":"List `impl` blocks matching a trait, a type, or both. With no filter returns every impl in the graph (use sparingly). Both arguments accept short names (e.g. `Display`) or qualified names. Surfaces information that is otherwise hard to query: trait-method dispatch targets, which types satisfy a given trait, and which traits a type implements.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 100).","type":"number"},"trait":{"description":"Trait name to filter by (short or qualified). Omit to include all traits.","type":"string"},"type":{"description":"Implementing type to filter by (short or qualified). Omit to include all types.","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_inheritance_depth","description":"Find the deepest class/interface inheritance hierarchies by walking extends chains.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_insert_at","description":"Insert content before or after a unique anchor in a file. The anchor can be a unique string or a 1-indexed line number. Fails if the anchor matches more than one line.","input_schema":{"type":"object","properties":{"anchor":{"description":"Unique string or line number (1-indexed) to insert at","type":"string"},"before":{"description":"If true, insert before the anchor line; if false, insert after (default: false)","type":"boolean"},"content":{"description":"Content to insert","type":"string"},"path":{"description":"Absolute or project-relative file path","type":"string"}},"required":["path","anchor","content"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_largest","description":"Rank nodes by size (line count). Find the largest classes, longest methods, biggest enums, etc.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"node_kind":{"description":"Filter by node kind (e.g. 'class', 'method', 'function', 'interface', 'enum', 'struct')","type":"string"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_module_api","description":"Show the public API surface of a file or directory: all pub symbols sorted by file and line.","input_schema":{"type":"object","properties":{"path":{"description":"File path or directory prefix to inspect","type":"string"}},"required":["path"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_multi_str_replace","description":"Apply multiple string replacements atomically in a single file. All replacements must match exactly once. If any replacement fails (0 or >1 matches), the entire operation is aborted and no changes are made.","input_schema":{"type":"object","properties":{"path":{"description":"Absolute or project-relative file path","type":"string"},"replacements":{"description":"Array of [old_str, new_str] pairs to replace","items":{"items":{"type":"string"},"maxItems":2,"minItems":2,"type":"array"},"type":"array"}},"required":["path","replacements"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_node","description":"Retrieve detailed information about a single node by its ID.","input_schema":{"type":"object","properties":{"node_id":{"description":"The unique node ID to retrieve","type":"string"}},"required":["node_id"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_outline","description":"Flat list of every top-level symbol defined in a file (functions, structs, enums, traits, classes, impls, etc.) — like a table of contents. Sorted by line number; no code bodies. Optional 'kinds' filter narrows to specific node kinds. Use this as the cheapest way to orient before zooming into a large file with tokensave_node, tokensave_body, or tokensave_read.","input_schema":{"type":"object","properties":{"file":{"description":"Project-relative path to the file (e.g. 'src/sync.rs').","type":"string"},"kinds":{"description":"Optional filter on node kinds. Common values: 'function', 'struct', 'enum', 'trait', 'impl', 'class', 'method', 'const'. Case-insensitive. Default: all kinds.","items":{"type":"string"},"type":"array"}},"required":["file"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_port_order","description":"Topological sort of symbols in a directory -- port leaves first, dependents after.","input_schema":{"type":"object","properties":{"kinds":{"description":"Node kinds to include (default: [\"function\", \"method\", \"class\", \"struct\", \"interface\", \"trait\", \"enum\", \"module\"])","items":{"type":"string"},"type":"array"},"limit":{"description":"Maximum number of symbols to return (default: 50)","type":"number"},"source_dir":{"description":"Path prefix for source code (e.g. 'src/python/')","type":"string"}},"required":["source_dir"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_port_status","description":"Compare symbols between source and target directories to track porting progress.","input_schema":{"type":"object","properties":{"kinds":{"description":"Node kinds to compare (default: [\"function\", \"method\", \"class\", \"struct\", \"interface\", \"trait\", \"enum\", \"module\"])","items":{"type":"string"},"type":"array"},"source_dir":{"description":"Path prefix for source code (e.g. 'src/python/')","type":"string"},"target_dir":{"description":"Path prefix for target code (e.g. 'src/rust/')","type":"string"}},"required":["source_dir","target_dir"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_pr_context","description":"Semantic summary of changes between two git refs for drafting a pull request description.","input_schema":{"type":"object","properties":{"base_ref":{"description":"Base branch or ref to compare against (default: 'main')","type":"string"},"head_ref":{"description":"Head branch or ref (default: 'HEAD')","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_rank","description":"Rank nodes by edge count for a given relationship type (calls, implements, extends, etc.).","input_schema":{"type":"object","properties":{"direction":{"description":"Edge direction: 'incoming' ranks targets (default, e.g. most-implemented interface), 'outgoing' ranks sources (e.g. class that implements the most interfaces)","enum":["incoming","outgoing"],"type":"string"},"edge_kind":{"description":"The relationship type to rank by (e.g. 'implements' to find most-implemented interfaces)","enum":["implements","extends","calls","uses","contains","annotates","derives_macro"],"type":"string"},"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"node_kind":{"description":"Optional filter for node kind (e.g. 'interface', 'class', 'trait', 'function', 'method')","type":"string"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}},"required":["edge_kind"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_read","description":"Read a file or its symbol map. Modes: 'full' (entire file), 'lines' (1-based inclusive byte-range slice via the 'lines' arg, e.g. '120-180'), 'map' (flat list of every top-level symbol from the graph — no source bytes touched), 'signatures' (functions and types with their cached signature). Cross-session cached: a re-call on an unchanged file returns a tiny stub with 'unchanged: true'.","input_schema":{"type":"object","properties":{"file":{"description":"Project-relative or absolute path to the file (e.g. 'src/sync.rs').","type":"string"},"lines":{"description":"Required when mode='lines'. Format 'A-B' or single 'A' (1-based, inclusive). E.g. '120-180' or '42'.","type":"string"},"mode":{"description":"Read mode. Default: 'full'.","enum":["full","lines","map","signatures"],"type":"string"}},"required":["file"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_record_code_area","description":"Record that the agent has been working in a code area (a file or directory). The first call sets an optional description; subsequent calls bump the touch counter and update last_touched_at. Recall with tokensave_session_recall.","input_schema":{"type":"object","properties":{"description":{"description":"Optional short description of what this area is or what was changed.","type":"string"},"path":{"description":"File or directory path (project-relative).","type":"string"}},"required":["path"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_record_decision","description":"Persist a design or architecture decision so it can be recalled in a future session via tokensave_session_recall. Use for choices the agent or user would otherwise have to re-explain (e.g. \"use JWT for auth — session tokens flagged by legal\"). Stored in the per-project DB.","input_schema":{"type":"object","properties":{"files":{"description":"File paths that the decision applies to.","items":{"type":"string"},"type":"array"},"reason":{"description":"Optional reason / context (e.g. \"session tokens flagged by legal\").","type":"string"},"tags":{"description":"Free-form tags for grouping (e.g. \"security\", \"performance\").","items":{"type":"string"},"type":"array"},"text":{"description":"The decision itself, in one sentence (e.g. \"use JWT for auth\").","type":"string"}},"required":["text"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_recursion","description":"Detect recursive and mutually-recursive call cycles in the call graph.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of cycles to return (default: 10)","type":"number"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_rename_preview","description":"Show all references to a symbol -- all edges where the node appears as source or target.","input_schema":{"type":"object","properties":{"node_id":{"description":"The unique node ID to find references for","type":"string"}},"required":["node_id"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_run_affected_tests","description":"Run `cargo test` for tests that cover the symbols in `changed_paths` (or, if omitted, the files changed in the working tree). Closes the loop opened by `tokensave_test_map` / `tokensave_test_risk` — emits pass/fail per test alongside the source nodes each test covers. Output is the libtest summary parsed into JSON.","input_schema":{"type":"object","properties":{"changed_paths":{"description":"Explicit file paths to compute affected tests from. Defaults to `git diff --name-only` against the working tree.","items":{"type":"string"},"type":"array"},"max_tests":{"description":"Cap on tests dispatched in a single invocation (default: 100).","type":"number"},"profile":{"description":"Cargo profile (default: debug).","enum":["debug","release"],"type":"string"},"timeout_secs":{"description":"Maximum wall time before the cargo subprocess is killed (default: 300).","type":"number"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_search","description":"Search for symbols (functions, structs, traits, etc.) in the code graph by name or keyword.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"query":{"description":"Search query string to match against symbol names","type":"string"}},"required":["query"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_session_end","description":"Re-scan and compare current health against session baseline (saved by session_start). Returns diff showing what improved or degraded.","input_schema":{"type":"object","properties":{},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_session_recall","description":"Recall persisted decisions (and optionally code areas) from past sessions. When `query` is provided, runs FTS5 search across decision text and reason. When omitted, returns the most recent decisions newest-first. Pair with tokensave_record_decision.","input_schema":{"type":"object","properties":{"include_code_areas":{"description":"If true, also return the top-touched code areas (default: false).","type":"boolean"},"limit":{"description":"Maximum decisions to return (default: 20, max: 200).","type":"number"},"query":{"description":"FTS5 query string (e.g. \"auth OR session\"). Omit for newest-first listing.","type":"string"},"since":{"description":"Unix timestamp; only return decisions made at-or-after this time.","type":"number"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_session_start","description":"Save current health metrics as baseline for later comparison via session_end. Call this before starting work.","input_schema":{"type":"object","properties":{},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_signature","description":"Return the signature-level metadata for symbols matching a qualified name — visibility, signature string (generics, params, return type, where clauses), docstring, async flag, and kind. No bodies. Use this instead of reading source files when you only need the public-API surface of a function, method, or type. Multiple rows can be returned (overloads, separate impls).","input_schema":{"type":"object","properties":{"node_id":{"description":"Optional: look up a single node by its ID instead of qualified_name.","type":"string"},"qualified_name":{"description":"The exact qualified name to look up.","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_signature_search","description":"Find functions and methods by signature shape: return type, parameter substring, async, or path. Searches the cached `signature` column on every Function/Method node. Substring-matched with case-sensitive compare; combine multiple criteria for narrower hits. Use tokensave_search for plain name lookups; this tool is for refactor questions like 'find every function returning Result<_, MyError>' or 'every async fn taking &mut self'.","input_schema":{"type":"object","properties":{"async":{"description":"When true, only return functions marked async. When false, exclude them. Omit to ignore async-ness.","type":"boolean"},"limit":{"description":"Maximum matches to return (default: 50, max: 500).","type":"number"},"params":{"description":"Substrings that must all appear in the parameter list portion of the signature. E.g. ['&mut self'], ['i32', 'String'].","items":{"type":"string"},"type":"array"},"path":{"description":"Filter to symbols defined under this directory.","type":"string"},"returns":{"description":"Substring that must appear in the return-type portion of the signature (after '->'). E.g. 'Result<', 'impl Future', 'Vec<u32>'.","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_similar","description":"Find symbols with similar names using full-text search and substring matching.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results (default: 10)","type":"number"},"symbol":{"description":"Symbol name to find similar matches for","type":"string"}},"required":["symbol"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_simplify_scan","description":"Quality analysis of changed files: duplications, dead code, coupling, and complexity hotspots.","input_schema":{"type":"object","properties":{"files":{"description":"Changed file paths to analyze","items":{"type":"string"},"type":"array"}},"required":["files"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_status","description":"Return aggregate statistics about the code graph (node/edge/file counts, DB size, etc.).","input_schema":{"type":"object","properties":{},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_str_replace","description":"Replace a unique string in a file with new content. Fails if the old string is not found or matches more than once. This is the safest edit primitive — use this instead of sed/awk.","input_schema":{"type":"object","properties":{"new_str":{"description":"Replacement string","type":"string"},"old_str":{"description":"Exact string to find and replace. Must match exactly once in the file.","type":"string"},"path":{"description":"Absolute or project-relative file path","type":"string"}},"required":["path","old_str","new_str"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_test_map","description":"Map source symbols to their test functions. Shows which tests cover which source code.","input_schema":{"type":"object","properties":{"file":{"description":"Source file path to find test coverage for","type":"string"},"node_id":{"description":"Specific node ID to find test coverage for (alternative to file)","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_test_risk","description":"Find high-risk source symbols with weak or no test coverage. Risk = (complexity + 1) × (fan_in + 1) × untested_multiplier. Answers: where should the next test go?","input_schema":{"type":"object","properties":{"include_tested":{"description":"Include already-tested functions in results (default: false)","type":"boolean"},"limit":{"description":"Maximum number of results to return (default: 20)","type":"number"},"path":{"description":"Filter to files under this directory path","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_todos","description":"Find TODO, FIXME, XXX, HACK, WIP, NOTE, and unimplemented markers across the project. Each result includes the marker kind, file, line, the comment text, and the enclosing symbol name (function/method) for quick orientation.","input_schema":{"type":"object","properties":{"kinds":{"description":"Marker kinds to include (default: TODO, FIXME, XXX, HACK, WIP, NOTE, UNIMPLEMENTED). Matched case-insensitively.","items":{"type":"string"},"type":"array"},"limit":{"description":"Maximum number of markers to return (default: 200, max: 2000)","type":"number"},"path":{"description":"Filter to files under this directory path (relative to project root)","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_type_hierarchy","description":"Show the full type hierarchy for a trait/interface/class: all implementors and extenders, recursively.","input_schema":{"type":"object","properties":{"max_depth":{"description":"Maximum inheritance depth to traverse (default: 5)","type":"number"},"node_id":{"description":"The type node ID to build the hierarchy for","type":"string"}},"required":["node_id"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_unsafe_patterns","description":"Find unwrap(), expect(), panic!(), todo!(), unimplemented!(), and unsafe { } sites across the project. Each match includes the file, line, kind, enclosing symbol, the source line, and an in_test flag derived from the path. Use this in security/quality reviews to surface panic sites before a release. Defaults to all kinds; pass `kinds` to narrow.","input_schema":{"type":"object","properties":{"exclude_tests":{"description":"When true, skips files whose path looks like a test (default: false).",