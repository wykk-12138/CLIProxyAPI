rties":{"scriptId":{"type":"string"}},"required":["scriptId"],"$schema":"http://json-schema.org/draft-07/schema#","additionalProperties":false},"eager_input_streaming":true},{"name":"jshook_v8_object_inspect","description":"Inspect a live JS object by objectId with property enumeration.","input_schema":{"type":"object","properties":{"address":{"type":"string"}},"required":["address"],"$schema":"http://json-schema.org/draft-07/schema#","additionalProperties":false},"eager_input_streaming":true},{"name":"jshook_v8_version_detect","description":"Detect V8 engine version, flags, and runtime capabilities.","input_schema":{"type":"object","properties":{},"additionalProperties":false},"eager_input_streaming":true},{"name":"jshook_watch","description":"Manage watch expressions for monitoring variable values during debugging.\n\nActions:\n- add: Add a watch expression (requires expression)\n- remove: Remove by watchId\n- list: List all watches\n- evaluate_all: Evaluate all enabled watches (optional callFrameId)\n- clear_all: Clear all watches","input_schema":{"type":"object","properties":{"action":{"type":"string","enum":["add","remove","list","evaluate_all","clear_all"]},"expression":{"type":"string"},"name":{"type":"string"},"watchId":{"type":"string"},"callFrameId":{"type":"string"}},"required":["action"],"$schema":"http://json-schema.org/draft-07/schema#","additionalProperties":false},"eager_input_streaming":true},{"name":"jshook_webcrack_unpack","description":"Run webcrack bundle unpacking and return extracted module graph.","input_schema":{"type":"object","properties":{"code":{"type":"string"},"unpack":{"type":"boolean"},"unminify":{"type":"boolean"},"jsx":{"type":"boolean"},"mangle":{"type":"boolean"},"outputDir":{"type":"string"},"forceOutput":{"type":"boolean"},"includeModuleCode":{"type":"boolean"},"maxBundleModules":{"type":"number","minimum":1,"maximum":10000},"mappings":{"type":"array","items":{"type":"object","properties":{"path":{"type":"string"},"pattern":{"type":"string"},"matchType":{"type":"string","enum":["includes","regex","exact"]},"target":{"type":"string","enum":["code","path"]}},"required":["path","pattern"]}}},"required":["code"],"$schema":"http://json-schema.org/draft-07/schema#","additionalProperties":false},"eager_input_streaming":true},{"name":"jshook_webpack_enumerate","description":"Enumerate webpack modules in current page and search for keywords.","input_schema":{"type":"object","properties":{"searchKeyword":{"type":"string"},"forceRequireAll":{"type":"boolean"},"maxResults":{"type":"number","minimum":1,"maximum":10000}},"$schema":"http://json-schema.org/draft-07/schema#","additionalProperties":false},"eager_input_streaming":true},{"name":"jshook_widget_challenge_solve","description":"Solve a widget challenge with hook, manual, or configured external service.","input_schema":{"type":"object","properties":{"siteKey":{"type":"string"},"pageUrl":{"type":"string"},"mode":{"type":"string","enum":["external_service","hook","manual"]},"provider":{"type":"string"},"apiKey":{"type":"string"},"timeoutMs":{"type":"number"},"injectToken":{"type":"boolean"}},"$schema":"http://json-schema.org/draft-07/schema#","additionalProperties":false},"eager_input_streaming":true},{"name":"jshook_ws_get_connections","description":"Get tracked WebSocket connections and frame counts.","input_schema":{"type":"object","properties":{},"additionalProperties":false},"eager_input_streaming":true},{"name":"jshook_ws_get_frames","description":"Get captured WebSocket frames with pagination and payload filter.","input_schema":{"type":"object","properties":{"direction":{"type":"string","enum":["sent","received","all"]},"limit":{"type":"number","minimum":1,"maximum":10000},"offset":{"type":"number","minimum":0},"payloadFilter":{"type":"string"}},"$schema":"http://json-schema.org/draft-07/schema#","additionalProperties":false},"eager_input_streaming":true},{"name":"jshook_ws_monitor","description":"Enable or disable WebSocket frame capture.","input_schema":{"type":"object","properties":{"action":{"type":"string","enum":["enable","disable"]},"urlFilter":{"type":"string"},"maxFrames":{"type":"number","minimum":1,"maximum":100000}},"required":["action"],"$schema":"http://json-schema.org/draft-07/schema#","additionalProperties":false},"eager_input_streaming":true},{"name":"look_at","description":"Extract basic information from media files (PDFs, images, diagrams) when a quick summary suffices over precise reading. Good for simple text-based content extraction without using the Read tool. NEVER use for visual precision, aesthetic evaluation, or exact accuracy - use Read tool instead for those cases.","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"file_path":{"description":"Absolute path to the file to analyze","type":"string"},"image_data":{"description":"Base64 encoded image data (for clipboard/pasted images)","type":"string"},"goal":{"description":"What specific information to extract from the file","type":"string"}},"required":["goal"]},"eager_input_streaming":true},{"name":"lsp_diagnostics","description":"Get errors, warnings, hints from language server BEFORE running build. Works for both single files and directories - file extension is auto-detected for directories.","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"filePath":{"description":"File or directory path to check diagnostics for","type":"string"},"severity":{"description":"Filter by severity level","type":"string","enum":["error","warning","information","hint","all"]}},"required":["filePath"]},"eager_input_streaming":true},{"name":"lsp_find_references","description":"Find ALL usages/references of a symbol across the entire workspace.","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"filePath":{"type":"string"},"line":{"description":"1-based","type":"number","minimum":1},"character":{"description":"0-based","type":"number","minimum":0},"includeDeclaration":{"description":"Include the declaration itself","type":"boolean"}},"required":["filePath","line","character"]},"eager_input_streaming":true},{"name":"lsp_goto_definition","description":"Jump to symbol definition. Find WHERE something is defined.","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"filePath":{"type":"string"},"line":{"description":"1-based","type":"number","minimum":1},"character":{"description":"0-based","type":"number","minimum":0}},"required":["filePath","line","character"]},"eager_input_streaming":true},{"name":"lsp_prepare_rename","description":"Check if rename is valid. Use BEFORE lsp_rename.","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"filePath":{"type":"string"},"line":{"description":"1-based","type":"number","minimum":1},"character":{"description":"0-based","type":"number","minimum":0}},"required":["filePath","line","character"]},"eager_input_streaming":true},{"name":"lsp_rename","description":"Rename symbol across entire workspace. APPLIES changes to all files.","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"filePath":{"type":"string"},"line":{"description":"1-based","type":"number","minimum":1},"character":{"description":"0-based","type":"number","minimum":0},"newName":{"description":"New symbol name","type":"string"}},"required":["filePath","line","character","newName"]},"eager_input_streaming":true},{"name":"lsp_symbols","description":"Get symbols from file (document) or search across workspace. Use scope='document' for file outline, scope='workspace' for project-wide symbol search.","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"filePath":{"description":"File path for LSP context","type":"string"},"scope":{"description":"'document' for file symbols, 'workspace' for project-wide search","default":"document","type":"string","enum":["document","workspace"]},"query":{"description":"Symbol name to search (required for workspace scope)","type":"string"},"limit":{"description":"Max results (default 50)","type":"number"}},"required":["filePath"]},"eager_input_streaming":true},{"name":"question","description":"Use this tool when you need to ask the user questions during execution. This allows you to:\n1. Gather user preferences or requirements\n2. Clarify ambiguous instructions\n3. Get decisions on implementation choices as you work\n4. Offer choices to the user about what direction to take.\n\nUsage notes:\n- When `custom` is enabled (default), a \"Type your own answer\" option is added automatically; don't include \"Other\" or catch-all options\n- Answers are returned as arrays of labels; set `multiple: true` to allow selecting more than one\n- If you recommend a specific option, make that the first option in the list and add \"(Recommended)\" at the end of the label\n","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"questions":{"type":"array","items":{"type":"object","properties":{"question":{"type":"string","description":"Complete question"},"header":{"type":"string","description":"Very short label (max 30 chars)"},"options":{"type":"array","items":{"type":"object","properties":{"label":{"type":"string","description":"Display text (1-5 words, concise)"},"description":{"type":"string","description":"Explanation of choice"}},"required":["label","description"]},"description":"Available choices"},"multiple":{"type":"boolean","description":"Allow selecting multiple choices"}},"required":["question","header","options"]},"description":"Questions to ask"}},"required":["questions"]},"eager_input_streaming":true},{"name":"read","description":"Read a file or directory from the local filesystem. If the path does not exist, an error is returned.\n\nUsage:\n- The filePath parameter should be an absolute path.\n- By default, this tool returns up to 2000 lines from the start of the file.\n- The offset parameter is the line number to start from (1-indexed).\n- To read later sections, call this tool again with a larger offset.\n- Use the grep tool to find specific content in large files or files with long lines.\n- If you are unsure of the correct file path, use the glob tool to look up filenames by glob pattern.\n- Contents are returned with each line prefixed by its line number as `<line>: <content>`. For example, if a file has contents \"foo\\n\", you will receive \"1: foo\\n\". For directories, entries are returned one per line (without line numbers) with a trailing `/` for subdirectories.\n- Any line longer than 2000 characters is truncated.\n- Call this tool in parallel when you know there are multiple files you want to read.\n- Avoid tiny repeated slices (30 line chunks). If you need more context, read a larger window.\n- This tool can read image files and PDFs and return them as file attachments.\n","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"filePath":{"type":"string","description":"The absolute path to the file or directory to read"},"offset":{"minimum":0,"type":"integer","maximum":9007199254740991,"description":"The line number to start reading from (1-indexed)"},"limit":{"minimum":0,"type":"integer","maximum":9007199254740991,"description":"The maximum number of lines to read (defaults to 2000)"}},"required":["filePath"]},"eager_input_streaming":true},{"name":"session_info","description":"Get metadata and statistics about an OpenCode session.\n\nReturns detailed information about a session including message count, date range, agents used, and available data sources.\n\nArguments:\n- session_id (required): Session ID to inspect\n\nExample output:\nSession ID: ses_abc123\nMessages: 45\nDate Range: 2025-12-20 10:30:00 to 2025-12-24 15:45:30\nDuration: 4 days, 5 hours\nAgents Used: build, oracle, librarian\nHas Todos: Yes (12 items, 8 completed)\nHas Transcript: Yes (234 entries)","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"session_id":{"description":"Session ID to inspect","type":"string"}},"required":["session_id"]},"eager_input_streaming":true},{"name":"session_list","description":"List all OpenCode sessions with optional filtering.\n\nReturns a list of available session IDs with metadata including message count, date range, and agents used.\n\nArguments:\n- limit (optional): Maximum number of sessions to return\n- from_date (optional): Filter sessions from this date (ISO 8601 format)\n- to_date (optional): Filter sessions until this date (ISO 8601 format)\n\nExample output:\n| Session ID | Messages | First | Last | Agents |\n|------------|----------|-------|------|--------|\n| ses_abc123 | 45 | 2025-12-20 | 2025-12-24 | build, oracle |\n| ses_def456 | 12 | 2025-12-19 | 2025-12-19 | build |","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"limit":{"description":"Maximum number of sessions to return","type":"number"},"from_date":{"description":"Filter sessions from this date (ISO 8601 format)","type":"string"},"to_date":{"description":"Filter sessions until this date (ISO 8601 format)","type":"string"},"project_path":{"description":"Filter sessions by project path (default: current working directory)","type":"string"}}},"eager_input_streaming":true},{"name":"session_read","description":"Read messages and history from an OpenCode session.\n\nReturns a formatted view of session messages with role, timestamp, and content. Optionally includes todos and transcript data.\n\nArguments:\n- session_id (required): Session ID to read\n- include_todos (optional): Include todo list if available (default: false)\n- include_transcript (optional): Include transcript log if available (default: false)\n- limit (optional): Maximum number of messages to return (default: all)\n\nExample output:\nSession: ses_abc123\nMessages: 45\nDate Range: 2025-12-20 to 2025-12-24\n\n[Message 1] user (2025-12-20 10:30:00)\nHello, can you help me with...\n\n[Message 2] assistant (2025-12-20 10:30:15)\nOf course! Let me help you with...","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"session_id":{"description":"Session ID to read","type":"string"},"include_todos":{"description":"Include todo list if available (default: false)","type":"boolean"},"include_transcript":{"description":"Include transcript log if available (default: false)","type":"boolean"},"limit":{"description":"Maximum number of messages to return (default: all)","type":"number"}},"required":["session_id"]},"eager_input_streaming":true},{"name":"session_search","description":"Search for content within OpenCode session messages.\n\nPerforms full-text search across session messages and returns matching excerpts with context.\n\nArguments:\n- query (required): Search query string\n- session_id (optional): Search within specific session only (default: all sessions)\n- case_sensitive (optional): Case-sensitive search (default: false)\n- limit (optional): Maximum number of results to return (default: 20)\n\nExample output:\nFound 3 matches across 2 sessions:\n\n[ses_abc123] Message msg_001 (user)\n...implement the **session manager** tool...\n\n[ses_abc123] Message msg_005 (assistant)\n...I'll create a **session manager** with full search...\n\n[ses_def456] Message msg_012 (user)\n...use the **session manager** to find...","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"query":{"description":"Search query string","type":"string"},"session_id":{"description":"Search within specific session only (default: all sessions)","type":"string"},"case_sensitive":{"description":"Case-sensitive search (default: false)","type":"boolean"},"limit":{"description":"Maximum number of results to return (default: 20)","type":"number"}},"required":["query"]},"eager_input_streaming":true},{"name":"skill","description":"Load a skill or execute a slash command to get detailed instructions for a specific task.\n\nSkills and commands provide specialized knowledge and step-by-step guidance.\nUse this when a task matches an available skill's or command's description.\n\n**How to use:**\n- Call with a skill name: name='code-review'\n- Call with a command name (without leading slash): name='publish'\n- The tool will return detailed instructions with your context applied.\n\n<available_items>\nPriority: project > user > opencode > builtin/plugin | Skills listed before commands\nInvoke via: skill(name=\"item-name\") - omit leading slash for commands.\n  <command>\n    <name>/autoatc</name>\n    <description>(project - Skill) Run this skill when the user asks to use the Android emulator/simulator to add a product to cart, run an ATC once, test app add-to-cart, or says phrases like \"用模拟器跑一次加车\", \"模拟器加车\", \"跑一次 ATC\", \"app 加车\", \"LDPlayer 加车\", \"Android 模拟器加车\". It executes the LDPlayer Android app replay flow via ADB/uiautomator and is useful for packet capture or Frida-hooked traffic analysis.</description>\n    <scope>project</scope>\n  </command>\n  <command>\n    <name>/playwright</name>\n    <description>(opencode - Skill) MUST USE for any browser-related tasks. Browser automation via Playwright MCP - verification, browsing, information gathering, web scraping, testing, screenshots, and all browser interactions.</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/frontend-ui-ux</name>\n    <description>(opencode - Skill) Designer-turned-developer who crafts stunning UI/UX even without design mockups</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/git-master</name>\n    <description>(opencode - Skill) MUST USE for ANY git operations. Atomic commits, rebase/squash, history search (blame, bisect, log -S). STRONGLY RECOMMENDED: Use with task(category='quick', load_skills=['git-master'], ...) to save context. Triggers: 'commit', 'rebase', 'squash', 'who wrote', 'when was X added', 'find the commit that'.</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/dev-browser</name>\n    <description>(opencode - Skill) Browser automation with persistent page state. Use when users ask to navigate websites, fill forms, take screenshots, extract web data, test web apps, or automate browser workflows. Trigger phrases include 'go to [url]', 'click on', 'fill out the form', 'take a screenshot', 'scrape', 'automate', 'test the website', 'log into', or any browser interaction request.</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/review-work</name>\n    <description>(opencode - Skill) Post-implementation review orchestrator. Launches 5 parallel background sub-agents: Oracle (goal/constraint verification), Oracle (code quality), Oracle (security), unspecified-high (hands-on QA execution), unspecified-high (context mining from GitHub/git/Slack/Notion). All must pass for review to pass. MUST USE after completing any significant implementation work. Triggers: 'review work', 'review my work', 'review changes', 'QA my work', 'verify implementation', 'check my work', 'validate changes', 'post-implementation review'.</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/ai-slop-remover</name>\n    <description>(opencode - Skill) Removes AI-generated code smells from a SINGLE file while preserving functionality. For multiple files, call in PARALLEL per file.</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/init-deep</name>\n    <description>(builtin) Initialize hierarchical AGENTS.md knowledge base</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/ralph-loop</name>\n    <description>(builtin) Start self-referential development loop until completion</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/ulw-loop</name>\n    <description>(builtin) Start ultrawork loop - continues until completion with ultrawork mode</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/cancel-ralph</name>\n    <description>(builtin) Cancel active Ralph Loop</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/refactor</name>\n    <description>(builtin) Intelligent refactoring command with LSP, AST-grep, architecture analysis, codemap, and TDD verification.</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/start-work</name>\n    <description>(builtin) Start Sisyphus work session from Prometheus plan</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/stop-continuation</name>\n    <description>(builtin) Stop all continuation mechanisms (ralph loop, todo continuation, boulder) for this session</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/remove-ai-slops</name>\n    <description>(builtin) Remove AI-generated code smells from branch changes and critically review the results</description>\n    <scope>builtin</scope>\n  </command>\n  <command>\n    <name>/handoff</name>\n    <description>(builtin) Create a detailed context summary for continuing work in a new session</description>\n    <scope>builtin</scope>\n  </command>\n</available_items>\nLoad a specialized skill that provides domain-specific instructions and workflows.\n\nWhen you recognize that a task matches one of the available skills listed below, use this tool to load the full skill instructions.\n\nThe skill will inject detailed instructions, workflows, and access to bundled resources (scripts, references, templates) into the conversation context.\n\nTool output includes a `<skill_content name=\"...\">` block with the loaded content.\n\nThe following skills provide specialized sets of instructions for particular tasks\nInvoke this tool to load a skill when a task matches one of the available skills listed below:\n\n## Available Skills\n- **autoatc**: Run this skill when the user asks to use the Android emulator/simulator to add a product to cart, run an ATC once, test app add-to-cart, or says phrases like \"用模拟器跑一次加车\", \"模拟器加车\", \"跑一次 ATC\", \"app 加车\", \"LDPlayer 加车\", \"Android 模拟器加车\". It executes the LDPlayer Android app replay flow via ADB/uiautomator and is useful for packet capture or Frida-hooked traffic analysis.\n- **customize-opencode**: Use ONLY when the user is editing or creating opencode's own configuration: opencode.json, opencode.jsonc, files under .opencode/, or files under ~/.config/opencode/. Also use when creating or fixing opencode agents, subagents, skills, plugins, MCP servers, or permission rules. Do not use for the user's own application code, or for any project that is not configuring opencode itself.","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"name":{"description":"The skill or command name (e.g., 'code-review' or 'publish'). Use without leading slash for commands.","type":"string"},"user_message":{"description":"Optional arguments or context for command invocation. Example: name='publish', user_message='patch'","type":"string"}},"required":["name"]},"eager_input_streaming":true},{"name":"skill_mcp","description":"Invoke MCP server operations from skill-embedded MCPs. Requires mcp_name plus exactly one of: tool_name, resource_name, or prompt_name.","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"mcp_name":{"description":"Name of the MCP server from skill config","type":"string"},"tool_name":{"description":"MCP tool to call","type":"string"},"resource_name":{"description":"MCP resource URI to read","type":"string"},"prompt_name":{"description":"MCP prompt to get","type":"string"},"arguments":{"description":"JSON string or object of arguments","anyOf":[{"type":"string"},{"type":"object","properties":{},"additionalProperties":false}]},"grep":{"description":"Regex pattern to filter output lines (only matching lines returned)","type":"string"}},"required":["mcp_name"]},"eager_input_streaming":true},{"name":"task","description":"Spawn agent task with category-based or direct agent selection.\n  \n  ⚠️  CRITICAL: You MUST provide EITHER category OR subagent_type. Omitting BOTH will FAIL.\n  \n  **COMMON MISTAKE (DO NOT DO THIS):**\n  ```\n  task(description=\"...\", prompt=\"...\", run_in_background=false)  // ❌ FAILS - missing category AND subagent_type\n  ```\n  \n  **CORRECT - Using category:**\n  ```\n  task(category=\"quick\", load_skills=[], description=\"Fix type error\", prompt=\"...\", run_in_background=false)\n  ```\n  \n  **CORRECT - Using subagent_type:**\n  ```\n  task(subagent_type=\"explore\", load_skills=[], description=\"Find patterns\", prompt=\"...\", run_in_background=true)\n  ```\n  \n  REQUIRED: Provide ONE of:\n  - category: For task delegation (uses Sisyphus-Junior with category-optimized model)\n  - subagent_type: For direct agent invocation (explore, librarian, oracle, etc.)\n  \n  **DO NOT provide both.** If category is provided, subagent_type is ignored.\n  \n  - load_skills: ALWAYS REQUIRED. Pass [] if no skills needed, or [\"skill-1\", \"skill-2\"] for category tasks.\n  - category: Use predefined category → Spawns Sisyphus-Junior with category config\n    Available categories:\n    - visual-engineering: Frontend, UI/UX, design, styling, animation\n  - artistry: Complex problem-solving with unconventional, creative approaches - beyond standard patterns\n  - ultrabrain: Use ONLY for genuinely hard, logic-heavy tasks. Give clear goals only, not step-by-step instructions.\n  - deep: Goal-oriented autonomous problem-solving. Thorough research before action. For hairy problems requiring deep understanding.\n  - quick: Trivial tasks - single file changes, typo fixes, simple modifications\n  - unspecified-low: Tasks that don't fit other categories, low effort required\n  - unspecified-high: Tasks that don't fit other categories, high effort required\n  - writing: Documentation, prose, technical writing\n  - subagent_type: Use specific agent directly (explore, librarian, oracle, metis, momus)\n  - run_in_background: REQUIRED. true=async (returns task_id), false=sync (waits). Use background=true ONLY for parallel exploration with 5+ independent queries.\n  - session_id: Existing Task session to continue (from previous task output). Continues agent with FULL CONTEXT PRESERVED - saves tokens, maintains continuity.\n  - command: The command that triggered this task (optional, for slash command tracking).\n  \n  **WHEN TO USE session_id:**\n  - Task failed/incomplete → session_id with \"fix: [specific issue]\"\n  - Need follow-up on previous result → session_id with additional question\n  - Multi-turn conversation with same agent → always session_id instead of new task\n  \n  Prompts MUST be in English.\nAvailable agent types and the tools they have access to:\n- build: The default agent. Executes tools based on configured permissions.\n- explore: Contextual grep for codebases. Answers \"Where is X?\", \"Which file has Y?\", \"Find the code that does Z\". Fire multiple in parallel for broad searches. Specify thoroughness: \"quick\" for basic, \"medium\" for moderate, \"very thorough\" for comprehensive analysis. (Explore - OhMyOpenCode)\n- general: General-purpose agent for researching complex questions and executing multi-step tasks. Use this agent to execute multiple units of work in parallel.\n- librarian: Specialized codebase understanding agent for multi-repository analysis, searching remote codebases, retrieving official documentation, and finding implementation examples using GitHub CLI, Context7, and Web Search. MUST BE USED when users ask to look up code in remote repositories, explain library internals, or find usage examples in open source. (Librarian - OhMyOpenCode)\n- Metis - Plan Consultant: Pre-planning consultant that analyzes requests to identify hidden intentions, ambiguities, and AI failure points. (Metis - OhMyOpenCode)\n- Momus - Plan Critic: Expert reviewer for evaluating work plans against rigorous clarity, verifiability, and completeness standards. (Momus - OhMyOpenCode)\n- multimodal-looker: Analyze media files (PDFs, images, diagrams) that require interpretation beyond raw text. Extracts specific information or summaries from documents, describes visual content. Use when you need analyzed/extracted data rather than literal file contents. (Multimodal-Looker - OhMyOpenCode)\n- oracle: Read-only consultation agent. High-IQ reasoning specialist for debugging hard problems and high-difficulty architecture design. (Oracle - OhMyOpenCode)\n- plan: Plan mode. Disallows all edit tools.\n- ​​​Prometheus - Plan Builder: Plan agent (Prometheus - OhMyOpenCode)\n- Sisyphus-Junior: Focused task executor. Same discipline, no delegation. (Sisyphus-Junior - OhMyOpenCode)","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"load_skills":{"description":"Skill names to inject. REQUIRED - pass [] if no skills needed.","type":"array","items":{"type":"string"}},"description":{"description":"Short task description (3-5 words). Auto-generated from prompt if omitted.","type":"string"},"prompt":{"description":"Full detailed prompt for the agent","type":"string"},"run_in_background":{"description":"REQUIRED. true=async (returns task_id), false=sync (waits). Use false for task delegation, true ONLY for parallel exploration.","type":"boolean"},"category":{"description":"REQUIRED if subagent_type not provided. Do NOT provide both category and subagent_type.","type":"string"},"subagent_type":{"description":"REQUIRED if category not provided. Do NOT provide both category and subagent_type.","type":"string"},"session_id":{"description":"Existing Task session to continue","type":"string"},"command":{"description":"The command that triggered this task","type":"string"}},"required":["load_skills","prompt","run_in_background"]},"eager_input_streaming":true},{"name":"task_create","description":"Create a new task with auto-generated ID and threadID recording.\n\nAuto-generates T-{uuid} ID, records threadID from context, sets status to \"pending\".\nReturns minimal response with task ID and subject.\n\n**IMPORTANT - Dependency Planning for Parallel Execution:**\nUse `blockedBy` to specify task IDs that must complete before this task can start.\nCalculate dependencies carefully to maximize parallel execution:\n- Tasks with no dependencies can run simultaneously\n- Only block a task if it truly depends on another's output\n- Minimize dependency chains to reduce sequential bottlenecks","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"subject":{"description":"Task subject (required)","type":"string"},"description":{"description":"Task description","type":"string"},"activeForm":{"description":"Active form (present continuous)","type":"string"},"metadata":{"description":"Task metadata","type":"object","propertyNames":{"type":"string"},"additionalProperties":{}},"blockedBy":{"description":"Task IDs blocking this task","type":"array","items":{"type":"string"}},"blocks":{"description":"Task IDs this task blocks","type":"array","items":{"type":"string"}},"repoURL":{"description":"Repository URL","type":"string"},"parentID":{"description":"Parent task ID","type":"string"}},"required":["subject"]},"eager_input_streaming":true},{"name":"task_get","description":"Retrieve a task by ID.\n\nReturns the full task object including all fields: id, subject, description, status, activeForm, blocks, blockedBy, owner, metadata, repoURL, parentID, and threadID.\n\nReturns null if the task does not exist or the file is invalid.","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"id":{"description":"Task ID to retrieve (format: T-{uuid})","type":"string"}},"required":["id"]},"eager_input_streaming":true},{"name":"task_list","description":"List all active tasks with summary information.\n    \nReturns tasks excluding completed and deleted statuses by default.\nFor each task's blockedBy field, filters to only include unresolved (non-completed) blockers.\nReturns summary format: id, subject, status, owner, blockedBy (not full description).","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{}},"eager_input_streaming":true},{"name":"task_update","description":"Update an existing task with new values.\n\nSupports updating: subject, description, status, activeForm, owner, metadata.\nFor blocks/blockedBy: use addBlocks/addBlockedBy to append (additive, not replacement).\nFor metadata: merge with existing, set key to null to delete.\nSyncs to OpenCode Todo API after update.\n\n**IMPORTANT - Dependency Management:**\nUse `addBlockedBy` to declare dependencies on other tasks.\nProperly managed dependencies enable maximum parallel execution.","input_schema":{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","properties":{"id":{"description":"Task ID (required)","type":"string"},"subject":{"description":"Task subject","type":"string"},"description":{"description":"Task description","type":"string"},"status":{"description":"Task status","type":"string","enum":["pending","in_progress","completed","deleted"]},"activeForm":{"description":"Active form (present continuous)","type":"string"},"owner":{"description":"Task owner (agent name)","type":"string"},"addBlocks":{"description":"Task IDs to add to blocks (additive, not replacement)","type":"array","items":{"type":"string"}},"addBlockedBy":{"description":"Task IDs to add to blockedBy (additive, not replacement)","type":"array","items":{"type":"string"}},"metadata":{"description":"Task metadata to merge (set key to null to delete)","type":"object","propertyNames":{"type":"string"},"additionalProperties":{}}},"required":["id"]},"eager_input_streaming":true},{"name":"tokensave_tokensave_affected","description":"Find test files affected by changed source files via dependency graph traversal.","input_schema":{"type":"object","properties":{"depth":{"description":"Maximum dependency traversal depth (default: 5)","type":"number"},"files":{"description":"List of changed file paths to analyze","items":{"type":"string"},"type":"array"},"filter":{"description":"Custom glob pattern for test files (default: common test patterns)","type":"string"}},"required":["files"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_body","description":"Return the full source body of a symbol by name (function, struct, const, etc.). Collapses search + node lookup + file read into a single call. When the name is ambiguous, returns multiple matches ranked by relevance.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of matching bodies to return when the name is ambiguous (default: 3, max: 20)","type":"number"},"symbol":{"description":"Symbol name to look up (e.g. 'resolve_provider_api_key', 'CCH_SEED', 'GraphStats'). Qualified names are also accepted.","type":"string"}},"required":["symbol"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_branch_diff","description":"Compare the code graphs of two branches. Shows symbols added, removed, and changed (signature differs) between base and head.","input_schema":{"type":"object","properties":{"base":{"description":"Base branch name (e.g. 'main'). Defaults to the project's default branch.","type":"string"},"file":{"description":"Optional file path filter — only show diffs for symbols in this file","type":"string"},"head":{"description":"Head branch name (e.g. 'feature/foo'). Defaults to the current branch.","type":"string"},"kind":{"description":"Optional kind filter — only show diffs for this symbol kind (e.g. 'function', 'struct')","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_branch_list","description":"List all tracked branches with their DB sizes, parent branch, and last sync time. Returns an empty list if multi-branch is not active.","input_schema":{"type":"object","properties":{},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_branch_search","description":"Search for symbols in another branch's code graph. Opens the target branch's DB and runs a search query against it.","input_schema":{"type":"object","properties":{"branch":{"description":"Branch name to search in (must be tracked via `tokensave branch add`)","type":"string"},"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"query":{"description":"Search query string to match against symbol names","type":"string"}},"required":["branch","query"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_by_qualified_name","description":"Look up nodes by their qualified name. Multiple rows can share a qualified name (overloads, generics, separate impl blocks). Useful for cross-run lookups where the content-hash node ID has changed.","input_schema":{"type":"object","properties":{"qualified_name":{"description":"The exact qualified name to look up.","type":"string"}},"required":["qualified_name"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_callees","description":"Find all callees of a given node (function, method, etc.) up to a specified depth. When a callee resolves to a trait method, the concrete impl methods reachable through that trait are also returned, tagged with `dispatch_via_trait: true` and a `dispatch_from` pointing at the trait method. Pass `resolve_dispatch: false` to disable this behaviour and get only direct call edges.","input_schema":{"type":"object","properties":{"max_depth":{"description":"Maximum traversal depth (default: 3)","type":"number"},"node_id":{"description":"The unique node ID to find callees for","type":"string"},"resolve_dispatch":{"description":"If true (default), append concrete impl methods for any trait-method callee.","type":"boolean"}},"required":["node_id"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_callers","description":"Find all callers of a given node (function, method, etc.) up to a specified depth.","input_schema":{"type":"object","properties":{"max_depth":{"description":"Maximum traversal depth (default: 3)","type":"number"},"node_id":{"description":"The unique node ID to find callers for","type":"string"}},"required":["node_id"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_callers_for","description":"Returns the caller set of every supplied node ID in one round-trip. Useful for clustering or similarity queries that need many caller sets at once. Returns a map of {node_id: [caller_id, …]}. Defaults to `calls` edges; pass `kind` to filter by `uses`, `type_of`, etc.","input_schema":{"type":"object","properties":{"kind":{"description":"Edge kind to filter by (default: \"calls\"). Pass an empty string to match all kinds.","type":"string"},"max_per_item":{"description":"Cap callers per item (default: 1000).","type":"number"},"node_ids":{"description":"Node IDs to look up callers for.","items":{"type":"string"},"type":"array"}},"required":["node_ids"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_changelog","description":"Generate a semantic diff/changelog between two git refs, categorizing symbols as added, removed, or modified.","input_schema":{"type":"object","properties":{"from_ref":{"description":"Starting git ref (commit, branch, tag)","type":"string"},"to_ref":{"description":"Ending git ref (commit, branch, tag)","type":"string"}},"required":["from_ref","to_ref"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_circular","description":"Detect circular dependencies between files in the code graph.","input_schema":{"type":"object","properties":{"max_depth":{"description":"Maximum cycle detection depth (default: 10)","type":"number"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_commit_context","description":"Semantic summary of uncommitted changes for drafting a commit message. Returns changed symbols, file roles, and recent commit style.","input_schema":{"type":"object","properties":{"staged_only":{"description":"If true, only analyze staged changes (default: false = all uncommitted changes)","type":"boolean"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_complexity","description":"Rank functions/methods by composite complexity score (lines + fan-out + fan-in).","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"node_kind":{"description":"Filter by node kind (default: function and method)","type":"string"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_config","description":"Query TOML or JSON config files by dotted key path. Use 'path' for a single file (e.g. Cargo.toml, tsconfig.json, pyproject.toml) or 'glob' to query the same key across multiple files. The 'key' is dot-separated (e.g. 'package.version', 'dependencies.tokio'). Returns each match's file, parsed value, and the line where the key is defined. Format is detected from extension: .toml → TOML, .json → JSON. \n\nDoes not query the code graph — pure filesystem + parser. Works on uninitialized projects.","input_schema":{"type":"object","properties":{"glob":{"description":"Glob pattern to match multiple config files (e.g. '**/Cargo.toml', 'crates/*/Cargo.toml'). Mutually exclusive with 'path'.","type":"string"},"key":{"description":"Dot-separated key path (e.g. 'package.version', 'dependencies.tokio.version'). Required.","type":"string"},"path":{"description":"Project-relative path to a single config file (e.g. 'Cargo.toml'). Mutually exclusive with 'glob'.","type":"string"}},"required":["key"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_constructors","description":"Find every place a given struct is instantiated as a literal ({ field: value, ... }). Each result includes the file, line, the field list present in that literal, and the set of fields missing relative to the struct's current definition (from the graph). The missing-fields list is the typical refactor signal: after adding a required field, this tool surfaces every site that needs updating, before cargo even compiles. Currently best-effort for Rust source; pattern matching ignores `match` arms and `if let` patterns.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of literal sites to return (default: 100, max: 1000).","type":"number"},"struct":{"description":"Struct name to search literal sites of (e.g. 'GraphStats', 'Config').","type":"string"}},"required":["struct"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_context","description":"Build an AI-ready context for a task description. Returns relevant symbols, relationships, and optionally code snippets.\n\nCALL BUDGET: 3 calls maximum for this project (4649 nodes). Stop after 3 calls. If the question is not fully answered, synthesise from what you have — do not exceed the budget.","input_schema":{"type":"object","properties":{"exclude_node_ids":{"description":"Node IDs to exclude from results (pass seen_node_ids from previous call for session deduplication)","items":{"type":"string"},"type":"array"},"include_code":{"description":"If true, include source code snippets for key symbols (default: false)","type":"boolean"},"keywords":{"description":"Extra search keywords for synonym expansion. Use this when the task uses conceptual terms that may not match symbol names — e.g. for 'authentication', pass [\"login\", \"session\", \"credential\", \"token\", \"auth\"]. The graph is searched for each keyword independently.","items":{"type":"string"},"type":"array"},"max_code_blocks":{"description":"Maximum number of code snippets when include_code is true (default: 5)","type":"number"},"max_nodes":{"description":"Maximum number of symbols to include (default: 20)","type":"number"},"max_per_file":{"description":"Maximum symbols from a single file in results. Prevents one large file from dominating (default: max_nodes/3, minimum 3)","type":"number"},"merge_adjacent":{"description":"When true, merge code blocks from the same file whose line ranges are adjacent or overlapping (default: false)","type":"boolean"},"mode":{"description":"Context mode: 'explore' (default) for general exploration, 'plan' for implementation planning (adds extension points, dependency order, test coverage)","enum":["explore","plan"],"type":"string"},"task":{"description":"Natural language description of the task or question","type":"string"}},"required":["task"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_coupling","description":"Rank files by coupling: fan_in (most depended on) or fan_out (most dependencies).","input_schema":{"type":"object","properties":{"direction":{"description":"fan_in: files depended on by the most others. fan_out: files that depend on the most others (default: fan_in)","enum":["fan_in","fan_out"],"type":"string"},"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_dead_code","description":"Find symbols with no incoming edges (potentially unreachable code). Always excludes `main` and `test*` functions. By default also excludes `pub` items (they may be referenced outside the indexed scope) — pass `include_public: true` to audit pub items with zero indexed callers, which is what you want for workspace-internal cleanup.","input_schema":{"type":"object","properties":{"include_public":{"description":"When true, do NOT exclude pub items. Default false.","type":"boolean"},"kinds":{"description":"Node kinds to check (default: [\"function\", \"method\"])","items":{"type":"string"},"type":"array"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_dependency_depth","description":"Show the longest file-level dependency chains. Files at the end of long chains are fragile to upstream changes.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of chains to return (default: 10)","type":"number"},"path":{"description":"Filter to files under this directory path","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_derives","description":"List `#[derive(...)]` macros attached to a type and the trait + method names each one synthesizes. Prevents dead-end searches for autogenerated symbols (e.g. `.clone()` from `#[derive(Clone)]`). Well-known derives (`Debug`, `Clone`, `Copy`, `Default`, `PartialEq`, `Eq`, `PartialOrd`, `Ord`, `Hash`, `Serialize`, `Deserialize`, `Display`, `Error`) carry full trait + method info; unknown / proc-macro derives surface with `well_known: false` so callers can still see the derive name.","input_schema":{"type":"object","properties":{"node_id":{"description":"Optional: look up the type by node ID instead.","type":"string"},"qualified_name":{"description":"The type's qualified name (or short name — same lookup as tokensave_by_qualified_name).","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_diagnose","description":"Parse raw `cargo check` / `cargo clippy` stderr text and map each diagnostic to the smallest containing graph node, with callers pre-attached so you can see what the failing code is reachable from. Diagnostics without a `--> file:line:col` span are dropped. Pass the full stderr capture; you do not need to pre-filter.","input_schema":{"type":"object","properties":{"cargo_output":{"description":"Raw stderr text from `cargo check` / `cargo clippy` / `rustc`.","type":"string"},"include_callers":{"description":"Attach up to 5 callers per diagnostic (default: true).","type":"boolean"},"max_diagnostics":{"description":"Cap on diagnostics in the response (default: 50).","type":"number"},"severity":{"description":"Filter by severity (default: all).","enum":["error","warning","all"],"type":"string"}},"required":["cargo_output"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_diagnostics","description":"Run the project's type-checker (cargo check for Rust, tsc for TypeScript, pyright for Python) and return structured errors and warnings. Each diagnostic includes file, line range, level, code, message, driver, and the enclosing graph node when one can be resolved. Replaces the recurring 'run cargo → parse text → read file' loop with a single structured response. \n\nNote: the cargo target dir is forced to .tokensave/target/ so we don't race with the user's interactive cargo runs. The first call against a fresh tree builds dependencies from scratch, which can take several minutes on large workspaces; subsequent calls are sub-second. Build scripts and proc macros from the project execute as part of cargo check — same trust model as running it manually.","input_schema":{"type":"object","properties":{"name":{"description":"Package name when scope='package' (e.g. 'tokensave', 'serde-json').","type":"string"},"path":{"description":"Project-relative file path when scope='file'.","type":"string"},"scope":{"description":"Run scope. Default 'workspace'. 'package' requires `name`; 'file' requires `path` and currently runs workspace + post-filter (cargo has no native single-file mode).","enum":["workspace","package","file"],"type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_diff_context","description":"Given changed file paths, return semantic context: which symbols were modified, what depends on them, and affected tests.","input_schema":{"type":"object","properties":{"depth":{"description":"Maximum impact traversal depth (default: 2)","type":"number"},"files":{"description":"List of changed file paths","items":{"type":"string"},"type":"array"}},"required":["files"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_distribution","description":"Show node kind distribution (classes, methods, fields, etc.) per file or directory.","input_schema":{"type":"object","properties":{"path":{"description":"Directory or file path prefix to filter (e.g. 'src/main/java/com/example'). Omit for entire codebase.","type":"string"},"summary":{"description":"If true, aggregate counts across all matching files instead of per-file breakdown (default: false)","type":"boolean"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_doc_coverage","description":"Find public symbols missing documentation (docstrings).","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 50)","type":"number"},"path":{"description":"Directory or file path prefix to filter (e.g. 'src/main'). Omit for entire codebase.","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_dsm","description":"Get the Design Structure Matrix: file dependency summary showing clusters, density, and layering violations.","input_schema":{"type":"object","properties":{"format":{"description":"Output format (default: stats)","enum":["stats","clusters","matrix"],"type":"string"},"max_files":{"description":"Maximum files in matrix format (default: 30)","type":"number"},"path":{"description":"Filter to files under this directory path","type":"string"}},"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_field_sites","description":"Find every read and write site of a named field across the codebase. Returns two arrays: write_sites (assignments to the field) and read_sites (everything else). Each entry includes file, line, enclosing symbol, and a source snippet. Useful when renaming, removing, or adding an invariant to a field — the write-site list is the exact blast radius. Pattern matches `.<field>` references; field-by-name is shorthand for any struct's same-named field, while `Struct::field` form narrows to a specific declaration.","input_schema":{"type":"object","properties":{"field":{"description":"Field name. Bare name ('last_sync_at') matches across structs; qualified form ('GraphStats::last_sync_at') narrows to one struct's field.","type":"string"},"limit":{"description":"Maximum sites per kind (default: 200, max: 2000).","type":"number"},"writes_only":{"description":"When true, returns only write_sites and omits reads. Default false.","type":"boolean"}},"required":["field"],"additionalProperties":false},"eager_input_streaming":true},{"name":"tokensave_tokensave_files","description":"List indexed project files. Use to explore file structure without reading file contents.","input_schema":{"type":"object","properties":{"format":{"description":"Output format: flat (one per line) or grouped by directory (default: grouped)","enum":["flat","grouped"],"type":"string"},"path":{"description":"Filter to files under this directory path","type":"str