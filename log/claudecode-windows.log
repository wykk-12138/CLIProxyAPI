e matching script responses.","input_schema":{"type":"object","properties":{"url":{"type":"string"},"replacement":{"type":"string"},"matchType":{"type":"string","enum":["exact","contains","regex"]}},"required":["url","replacement"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__search_in_scripts","description":"Search collected scripts by keyword or regex pattern.","input_schema":{"type":"object","properties":{"keyword":{"type":"string"},"isRegex":{"type":"boolean"},"caseSensitive":{"type":"boolean"},"contextLines":{"type":"number","minimum":0,"maximum":50},"maxMatches":{"type":"number","minimum":1,"maximum":10000},"returnSummary":{"type":"boolean"},"maxContextSize":{"type":"number","minimum":1000,"maximum":1000000}},"required":["keyword"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__search_tools","description":"Search 181 tools across 11 capability domains. This includes built-in tools plus any loaded plugin/workflow tools (0 currently loaded). In search-tier sessions, call this before assuming a capability is unavailable. Use activate_tools for exact matches, activate_domain for an entire domain. Domains: browser (63) | network (37) | core (20) | debugger (16) | maintenance (12) | v8-inspector (8) | graphql (6) | workflow (6) | encoding (5) | streaming (5) | shared-state-board (3). Query tip: before searching, distill your intent into key concepts (action verb + target + domain). Pass distilled keywords, not full sentences — the search engine works on token matching, not semantic understanding.","input_schema":{"type":"object","properties":{"query":{"type":"string","description":"Before calling, distill your intent into 2-5 key concepts: what action, on what target, in which domain. Pass only those distilled keywords — not the original user request."},"top_k":{"description":"Max results to return (default: 10, max: 30)","type":"number"},"auto_activate":{"description":"Auto-activate found tools so they are immediately callable. Set false to only search without activating (default: true)","type":"boolean"}},"required":["query"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__smart_cache_cleanup","description":"Evict LRU and stale entries while preserving hot data.","input_schema":{"type":"object","properties":{"targetSize":{"type":"number"}},"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__sse_get_events","description":"Get captured SSE events with filters and pagination.","input_schema":{"type":"object","properties":{"sourceUrl":{"type":"string"},"eventType":{"type":"string"},"limit":{"type":"number","minimum":1,"maximum":10000},"offset":{"type":"number","minimum":0}},"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__sse_monitor_enable","description":"Enable SSE monitoring by injecting EventSource interceptor.","input_schema":{"type":"object","properties":{"urlFilter":{"type":"string"},"maxEvents":{"type":"number","minimum":1,"maximum":100000},"persistent":{"type":"boolean"}},"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__state_board","description":"CRUD operations on the cross-tool shared state board.","input_schema":{"type":"object","properties":{"action":{"type":"string","enum":["set","get","delete","list","history","clear"]},"key":{"type":"string"},"value":{"type":"object","propertyNames":{"type":"string"},"additionalProperties":{}},"namespace":{"type":"string"},"ttlSeconds":{"type":"number"},"includeValues":{"type":"boolean"},"limit":{"type":"number"},"keyPattern":{"type":"string"}},"required":["action"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__state_board_io","description":"Serialize state board to JSON or restore from a previous export.","input_schema":{"type":"object","properties":{"action":{"type":"string","enum":["export","import"]},"namespace":{"type":"string"},"keyPattern":{"type":"string"},"data":{"type":"object","propertyNames":{"type":"string"},"additionalProperties":{}},"overwrite":{"type":"boolean"}},"required":["action"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__state_board_watch","description":"Watch state board keys for changes with configurable polling.","input_schema":{"type":"object","properties":{"action":{"type":"string","enum":["start","poll","stop"]},"key":{"type":"string"},"namespace":{"type":"string"},"pollIntervalMs":{"type":"number"},"watchId":{"type":"string"}},"required":["action"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__stealth_configure_jitter","description":"Configure CDP timing jitter.","input_schema":{"type":"object","properties":{"enabled":{"type":"boolean"},"minDelayMs":{"type":"number"},"maxDelayMs":{"type":"number"},"burstMode":{"type":"boolean"}},"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__stealth_generate_fingerprint","description":"Generate a browser fingerprint.","input_schema":{"type":"object","properties":{"os":{"type":"string","enum":["windows","macos","linux"]},"browser":{"type":"string","enum":["chrome","firefox"]},"locale":{"type":"string"}},"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__stealth_inject","description":"Inject anti-detection scripts to reduce bot fingerprint exposure.","input_schema":{"type":"object","properties":{}}},{"name":"mcp__jshook__stealth_set_user_agent","description":"Set User-Agent and fingerprint.","input_schema":{"type":"object","properties":{"platform":{"type":"string","enum":["windows","mac","linux"]}},"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__stealth_verify","description":"Run anti-detection checks.","input_schema":{"type":"object","properties":{}}},{"name":"mcp__jshook__tab_workflow","description":"Cross-tab coordination.","input_schema":{"type":"object","properties":{"action":{"type":"string","enum":["list","alias_bind","alias_open","navigate","wait_for","context_set","context_get","transfer","clear"]},"alias":{"type":"string"},"fromAlias":{"type":"string"},"index":{"type":"number"},"url":{"type":"string"},"selector":{"type":"string"},"waitForText":{"type":"string"},"key":{"type":"string"},"value":{"type":"string"},"expression":{"type":"string"},"timeoutMs":{"type":"number"}},"required":["action"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__understand_code","description":"Run semantic code analysis for structure, behavior, and risks.","input_schema":{"type":"object","properties":{"code":{"type":"string"},"context":{"type":"object","propertyNames":{"type":"string"},"additionalProperties":{}},"focus":{"type":"string","enum":["structure","business","security","all"]}},"required":["code"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__v8_bytecode_extract","description":"Extract V8 bytecode for a script by scriptId, with source fallback.","input_schema":{"type":"object","properties":{"scriptId":{"type":"string"},"functionOffset":{"type":"number"},"includeSourceFallback":{"type":"boolean"}},"required":["scriptId"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__v8_heap_diff","description":"Compare two heap snapshots to find allocation changes.","input_schema":{"type":"object","properties":{"beforeSnapshotId":{"type":"string"},"afterSnapshotId":{"type":"string"}},"required":["beforeSnapshotId","afterSnapshotId"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__v8_heap_snapshot_analyze","description":"Analyze a heap snapshot: retained size, constructor distribution, dominators.","input_schema":{"type":"object","properties":{"snapshotId":{"type":"string"}},"required":["snapshotId"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__v8_heap_snapshot_capture","description":"Capture a V8 heap snapshot for offline analysis.","input_schema":{"type":"object","properties":{}}},{"name":"mcp__jshook__v8_heap_stats","description":"Report V8 heap statistics: used, total, external.","input_schema":{"type":"object","properties":{}}},{"name":"mcp__jshook__v8_jit_inspect","description":"Report JIT compilation status and optimization tier for a script.","input_schema":{"type":"object","properties":{"scriptId":{"type":"string"}},"required":["scriptId"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__v8_object_inspect","description":"Inspect a live JS object by objectId with property enumeration.","input_schema":{"type":"object","properties":{"address":{"type":"string"}},"required":["address"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__v8_version_detect","description":"Detect V8 engine version, flags, and runtime capabilities.","input_schema":{"type":"object","properties":{}}},{"name":"mcp__jshook__watch","description":"Manage watch expressions for monitoring variable values during debugging.\n\nActions:\n- add: Add a watch expression (requires expression)\n- remove: Remove by watchId\n- list: List all watches\n- evaluate_all: Evaluate all enabled watches (optional callFrameId)\n- clear_all: Clear all watches","input_schema":{"type":"object","properties":{"action":{"type":"string","enum":["add","remove","list","evaluate_all","clear_all"]},"expression":{"type":"string"},"name":{"type":"string"},"watchId":{"type":"string"},"callFrameId":{"type":"string"}},"required":["action"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__webcrack_unpack","description":"Run webcrack bundle unpacking and return extracted module graph.","input_schema":{"type":"object","properties":{"code":{"type":"string"},"unpack":{"type":"boolean"},"unminify":{"type":"boolean"},"jsx":{"type":"boolean"},"mangle":{"type":"boolean"},"outputDir":{"type":"string"},"forceOutput":{"type":"boolean"},"includeModuleCode":{"type":"boolean"},"maxBundleModules":{"type":"number","minimum":1,"maximum":10000},"mappings":{"type":"array","items":{"type":"object","properties":{"path":{"type":"string"},"pattern":{"type":"string"},"matchType":{"type":"string","enum":["includes","regex","exact"]},"target":{"type":"string","enum":["code","path"]}},"required":["path","pattern"]}}},"required":["code"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__webpack_enumerate","description":"Enumerate webpack modules in current page and search for keywords.","input_schema":{"type":"object","properties":{"searchKeyword":{"type":"string"},"forceRequireAll":{"type":"boolean"},"maxResults":{"type":"number","minimum":1,"maximum":10000}},"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__widget_challenge_solve","description":"Solve a widget challenge with hook, manual, or configured external service.","input_schema":{"type":"object","properties":{"siteKey":{"type":"string"},"pageUrl":{"type":"string"},"mode":{"type":"string","enum":["external_service","hook","manual"]},"provider":{"type":"string"},"apiKey":{"type":"string"},"timeoutMs":{"type":"number"},"injectToken":{"type":"boolean"}},"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__ws_get_connections","description":"Get tracked WebSocket connections and frame counts.","input_schema":{"type":"object","properties":{}}},{"name":"mcp__jshook__ws_get_frames","description":"Get captured WebSocket frames with pagination and payload filter.","input_schema":{"type":"object","properties":{"direction":{"type":"string","enum":["sent","received","all"]},"limit":{"type":"number","minimum":1,"maximum":10000},"offset":{"type":"number","minimum":0},"payloadFilter":{"type":"string"}},"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__jshook__ws_monitor","description":"Enable or disable WebSocket frame capture.","input_schema":{"type":"object","properties":{"action":{"type":"string","enum":["enable","disable"]},"urlFilter":{"type":"string"},"maxFrames":{"type":"number","minimum":1,"maximum":100000}},"required":["action"],"$schema":"http://json-schema.org/draft-07/schema#"}},{"name":"mcp__tokensave__tokensave_affected","description":"Find test files affected by changed source files via dependency graph traversal.","input_schema":{"type":"object","properties":{"depth":{"description":"Maximum dependency traversal depth (default: 5)","type":"number"},"files":{"description":"List of changed file paths to analyze","items":{"type":"string"},"type":"array"},"filter":{"description":"Custom glob pattern for test files (default: common test patterns)","type":"string"}},"required":["files"]}},{"name":"mcp__tokensave__tokensave_ast_grep_rewrite","description":"Perform structural code rewrite using ast-grep. The pattern and rewrite use ast-grep's SGPattern syntax. Fails if ast-grep is not installed.","input_schema":{"type":"object","properties":{"path":{"description":"Absolute or project-relative file path","type":"string"},"pattern":{"description":"ast-grep search pattern (SGPattern syntax)","type":"string"},"rewrite":{"description":"ast-grep rewrite rule","type":"string"}},"required":["path","pattern","rewrite"]}},{"name":"mcp__tokensave__tokensave_body","description":"Return the full source body of a symbol by name (function, struct, const, etc.). Collapses search + node lookup + file read into a single call. When the name is ambiguous, returns multiple matches ranked by relevance.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of matching bodies to return when the name is ambiguous (default: 3, max: 20)","type":"number"},"symbol":{"description":"Symbol name to look up (e.g. 'resolve_provider_api_key', 'CCH_SEED', 'GraphStats'). Qualified names are also accepted.","type":"string"}},"required":["symbol"]}},{"name":"mcp__tokensave__tokensave_branch_diff","description":"Compare the code graphs of two branches. Shows symbols added, removed, and changed (signature differs) between base and head.","input_schema":{"type":"object","properties":{"base":{"description":"Base branch name (e.g. 'main'). Defaults to the project's default branch.","type":"string"},"file":{"description":"Optional file path filter — only show diffs for symbols in this file","type":"string"},"head":{"description":"Head branch name (e.g. 'feature/foo'). Defaults to the current branch.","type":"string"},"kind":{"description":"Optional kind filter — only show diffs for this symbol kind (e.g. 'function', 'struct')","type":"string"}}}},{"name":"mcp__tokensave__tokensave_branch_list","description":"List all tracked branches with their DB sizes, parent branch, and last sync time. Returns an empty list if multi-branch is not active.","input_schema":{"type":"object","properties":{}}},{"name":"mcp__tokensave__tokensave_branch_search","description":"Search for symbols in another branch's code graph. Opens the target branch's DB and runs a search query against it.","input_schema":{"type":"object","properties":{"branch":{"description":"Branch name to search in (must be tracked via `tokensave branch add`)","type":"string"},"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"query":{"description":"Search query string to match against symbol names","type":"string"}},"required":["branch","query"]}},{"name":"mcp__tokensave__tokensave_by_qualified_name","description":"Look up nodes by their qualified name. Multiple rows can share a qualified name (overloads, generics, separate impl blocks). Useful for cross-run lookups where the content-hash node ID has changed.","input_schema":{"type":"object","properties":{"qualified_name":{"description":"The exact qualified name to look up.","type":"string"}},"required":["qualified_name"]}},{"name":"mcp__tokensave__tokensave_callees","description":"Find all callees of a given node (function, method, etc.) up to a specified depth.","input_schema":{"type":"object","properties":{"max_depth":{"description":"Maximum traversal depth (default: 3)","type":"number"},"node_id":{"description":"The unique node ID to find callees for","type":"string"}},"required":["node_id"]}},{"name":"mcp__tokensave__tokensave_callers","description":"Find all callers of a given node (function, method, etc.) up to a specified depth.","input_schema":{"type":"object","properties":{"max_depth":{"description":"Maximum traversal depth (default: 3)","type":"number"},"node_id":{"description":"The unique node ID to find callers for","type":"string"}},"required":["node_id"]}},{"name":"mcp__tokensave__tokensave_callers_for","description":"Returns the caller set of every supplied node ID in one round-trip. Useful for clustering or similarity queries that need many caller sets at once. Returns a map of {node_id: [caller_id, ...]}. Defaults to `calls` edges; pass `kind` to filter by `uses`, `type_of`, etc.","input_schema":{"type":"object","properties":{"kind":{"description":"Edge kind to filter by (default: \"calls\"). Pass an empty string to match all kinds.","type":"string"},"max_per_item":{"description":"Cap callers per item (default: 1000).","type":"number"},"node_ids":{"description":"Node IDs to look up callers for.","items":{"type":"string"},"type":"array"}},"required":["node_ids"]}},{"name":"mcp__tokensave__tokensave_changelog","description":"Generate a semantic diff/changelog between two git refs, categorizing symbols as added, removed, or modified.","input_schema":{"type":"object","properties":{"from_ref":{"description":"Starting git ref (commit, branch, tag)","type":"string"},"to_ref":{"description":"Ending git ref (commit, branch, tag)","type":"string"}},"required":["from_ref","to_ref"]}},{"name":"mcp__tokensave__tokensave_circular","description":"Detect circular dependencies between files in the code graph.","input_schema":{"type":"object","properties":{"max_depth":{"description":"Maximum cycle detection depth (default: 10)","type":"number"}}}},{"name":"mcp__tokensave__tokensave_commit_context","description":"Semantic summary of uncommitted changes for drafting a commit message. Returns changed symbols, file roles, and recent commit style.","input_schema":{"type":"object","properties":{"staged_only":{"description":"If true, only analyze staged changes (default: false = all uncommitted changes)","type":"boolean"}}}},{"name":"mcp__tokensave__tokensave_complexity","description":"Rank functions/methods by composite complexity score (lines + fan-out + fan-in).","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"node_kind":{"description":"Filter by node kind (default: function and method)","type":"string"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}}}},{"name":"mcp__tokensave__tokensave_context","description":"Build an AI-ready context for a task description. Returns relevant symbols, relationships, and optionally code snippets.\n\nCALL BUDGET: 3 calls maximum for this project (4610 nodes). Stop after 3 calls. If the question is not fully answered, synthesise from what you have — do not exceed the budget.","input_schema":{"type":"object","properties":{"exclude_node_ids":{"description":"Node IDs to exclude from results (pass seen_node_ids from previous call for session deduplication)","items":{"type":"string"},"type":"array"},"include_code":{"description":"If true, include source code snippets for key symbols (default: false)","type":"boolean"},"keywords":{"description":"Extra search keywords for synonym expansion. Use this when the task uses conceptual terms that may not match symbol names — e.g. for 'authentication', pass [\"login\", \"session\", \"credential\", \"token\", \"auth\"]. The graph is searched for each keyword independently.","items":{"type":"string"},"type":"array"},"max_code_blocks":{"description":"Maximum number of code snippets when include_code is true (default: 5)","type":"number"},"max_nodes":{"description":"Maximum number of symbols to include (default: 20)","type":"number"},"max_per_file":{"description":"Maximum symbols from a single file in results. Prevents one large file from dominating (default: max_nodes/3, minimum 3)","type":"number"},"merge_adjacent":{"description":"When true, merge code blocks from the same file whose line ranges are adjacent or overlapping (default: false)","type":"boolean"},"mode":{"description":"Context mode: 'explore' (default) for general exploration, 'plan' for implementation planning (adds extension points, dependency order, test coverage)","enum":["explore","plan"],"type":"string"},"task":{"description":"Natural language description of the task or question","type":"string"}},"required":["task"]}},{"name":"mcp__tokensave__tokensave_coupling","description":"Rank files by coupling: fan_in (most depended on) or fan_out (most dependencies).","input_schema":{"type":"object","properties":{"direction":{"description":"fan_in: files depended on by the most others. fan_out: files that depend on the most others (default: fan_in)","enum":["fan_in","fan_out"],"type":"string"},"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}}}},{"name":"mcp__tokensave__tokensave_dead_code","description":"Find symbols with no incoming edges (potentially unreachable code). Excludes main, test functions, and public items.","input_schema":{"type":"object","properties":{"kinds":{"description":"Node kinds to check (default: [\"function\", \"method\"])","items":{"type":"string"},"type":"array"}}}},{"name":"mcp__tokensave__tokensave_dependency_depth","description":"Show the longest file-level dependency chains. Files at the end of long chains are fragile to upstream changes.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of chains to return (default: 10)","type":"number"},"path":{"description":"Filter to files under this directory path","type":"string"}}}},{"name":"mcp__tokensave__tokensave_diff_context","description":"Given changed file paths, return semantic context: which symbols were modified, what depends on them, and affected tests.","input_schema":{"type":"object","properties":{"depth":{"description":"Maximum impact traversal depth (default: 2)","type":"number"},"files":{"description":"List of changed file paths","items":{"type":"string"},"type":"array"}},"required":["files"]}},{"name":"mcp__tokensave__tokensave_distribution","description":"Show node kind distribution (classes, methods, fields, etc.) per file or directory.","input_schema":{"type":"object","properties":{"path":{"description":"Directory or file path prefix to filter (e.g. 'src/main/java/com/example'). Omit for entire codebase.","type":"string"},"summary":{"description":"If true, aggregate counts across all matching files instead of per-file breakdown (default: false)","type":"boolean"}}}},{"name":"mcp__tokensave__tokensave_doc_coverage","description":"Find public symbols missing documentation (docstrings).","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 50)","type":"number"},"path":{"description":"Directory or file path prefix to filter (e.g. 'src/main'). Omit for entire codebase.","type":"string"}}}},{"name":"mcp__tokensave__tokensave_dsm","description":"Get the Design Structure Matrix: file dependency summary showing clusters, density, and layering violations.","input_schema":{"type":"object","properties":{"format":{"description":"Output format (default: stats)","enum":["stats","clusters","matrix"],"type":"string"},"max_files":{"description":"Maximum files in matrix format (default: 30)","type":"number"},"path":{"description":"Filter to files under this directory path","type":"string"}}}},{"name":"mcp__tokensave__tokensave_files","description":"List indexed project files. Use to explore file structure without reading file contents.","input_schema":{"type":"object","properties":{"format":{"description":"Output format: flat (one per line) or grouped by directory (default: grouped)","enum":["flat","grouped"],"type":"string"},"path":{"description":"Filter to files under this directory path","type":"string"},"pattern":{"description":"Filter files matching this glob pattern (e.g. '**/*.rs')","type":"string"}}}},{"name":"mcp__tokensave__tokensave_gini","description":"Compute inequality (Gini coefficient) for any metric across files or symbols. Detects god files and uneven complexity distribution.","input_schema":{"type":"object","properties":{"limit":{"description":"Number of top outliers to return (default: 10)","type":"number"},"metric":{"description":"Metric to measure inequality for (default: complexity)","enum":["complexity","lines","fan_in","fan_out","members"],"type":"string"},"path":{"description":"Filter to files under this directory path","type":"string"},"scope":{"description":"Aggregate per file or per symbol (default: file)","enum":["file","symbol"],"type":"string"}}}},{"name":"mcp__tokensave__tokensave_god_class","description":"Find classes with the most members (methods + fields).","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}}}},{"name":"mcp__tokensave__tokensave_health","description":"Get quality signal (0-10000) with root cause breakdown (acyclicity, depth, equality, redundancy, modularity). Quality signal = geometric mean of 5 dimensions — maximize this ONE number.","input_schema":{"type":"object","properties":{"details":{"description":"If true, include full dimension breakdown (default: false)","type":"boolean"},"path":{"description":"Filter to files under this directory path","type":"string"}}}},{"name":"mcp__tokensave__tokensave_hotspots","description":"Find symbols with the highest connectivity (most incoming + outgoing edges).","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of hotspots to return (default: 10)","type":"number"}}}},{"name":"mcp__tokensave__tokensave_impact","description":"Compute the impact radius of a node: all symbols that directly or indirectly depend on it.","input_schema":{"type":"object","properties":{"max_depth":{"description":"Maximum traversal depth (default: 3)","type":"number"},"node_id":{"description":"The unique node ID to compute impact for","type":"string"}},"required":["node_id"]}},{"name":"mcp__tokensave__tokensave_inheritance_depth","description":"Find the deepest class/interface inheritance hierarchies by walking extends chains.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}}}},{"name":"mcp__tokensave__tokensave_insert_at","description":"Insert content before or after a unique anchor in a file. The anchor can be a unique string or a 1-indexed line number. Fails if the anchor matches more than one line.","input_schema":{"type":"object","properties":{"anchor":{"description":"Unique string or line number (1-indexed) to insert at","type":"string"},"before":{"description":"If true, insert before the anchor line; if false, insert after (default: false)","type":"boolean"},"content":{"description":"Content to insert","type":"string"},"path":{"description":"Absolute or project-relative file path","type":"string"}},"required":["path","anchor","content"]}},{"name":"mcp__tokensave__tokensave_largest","description":"Rank nodes by size (line count). Find the largest classes, longest methods, biggest enums, etc.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"node_kind":{"description":"Filter by node kind (e.g. 'class', 'method', 'function', 'interface', 'enum', 'struct')","type":"string"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}}}},{"name":"mcp__tokensave__tokensave_module_api","description":"Show the public API surface of a file or directory: all pub symbols sorted by file and line.","input_schema":{"type":"object","properties":{"path":{"description":"File path or directory prefix to inspect","type":"string"}},"required":["path"]}},{"name":"mcp__tokensave__tokensave_multi_str_replace","description":"Apply multiple string replacements atomically in a single file. All replacements must match exactly once. If any replacement fails (0 or >1 matches), the entire operation is aborted and no changes are made.","input_schema":{"type":"object","properties":{"path":{"description":"Absolute or project-relative file path","type":"string"},"replacements":{"description":"Array of [old_str, new_str] pairs to replace","items":{"items":{"type":"string"},"maxItems":2,"minItems":2,"type":"array"},"type":"array"}},"required":["path","replacements"]}},{"name":"mcp__tokensave__tokensave_node","description":"Retrieve detailed information about a single node by its ID.","input_schema":{"type":"object","properties":{"node_id":{"description":"The unique node ID to retrieve","type":"string"}},"required":["node_id"]}},{"name":"mcp__tokensave__tokensave_port_order","description":"Topological sort of symbols in a directory -- port leaves first, dependents after.","input_schema":{"type":"object","properties":{"kinds":{"description":"Node kinds to include (default: [\"function\", \"method\", \"class\", \"struct\", \"interface\", \"trait\", \"enum\", \"module\"])","items":{"type":"string"},"type":"array"},"limit":{"description":"Maximum number of symbols to return (default: 50)","type":"number"},"source_dir":{"description":"Path prefix for source code (e.g. 'src/python/')","type":"string"}},"required":["source_dir"]}},{"name":"mcp__tokensave__tokensave_port_status","description":"Compare symbols between source and target directories to track porting progress.","input_schema":{"type":"object","properties":{"kinds":{"description":"Node kinds to compare (default: [\"function\", \"method\", \"class\", \"struct\", \"interface\", \"trait\", \"enum\", \"module\"])","items":{"type":"string"},"type":"array"},"source_dir":{"description":"Path prefix for source code (e.g. 'src/python/')","type":"string"},"target_dir":{"description":"Path prefix for target code (e.g. 'src/rust/')","type":"string"}},"required":["source_dir","target_dir"]}},{"name":"mcp__tokensave__tokensave_pr_context","description":"Semantic summary of changes between two git refs for drafting a pull request description.","input_schema":{"type":"object","properties":{"base_ref":{"description":"Base branch or ref to compare against (default: 'main')","type":"string"},"head_ref":{"description":"Head branch or ref (default: 'HEAD')","type":"string"}}}},{"name":"mcp__tokensave__tokensave_rank","description":"Rank nodes by edge count for a given relationship type (calls, implements, extends, etc.).","input_schema":{"type":"object","properties":{"direction":{"description":"Edge direction: 'incoming' ranks targets (default, e.g. most-implemented interface), 'outgoing' ranks sources (e.g. class that implements the most interfaces)","enum":["incoming","outgoing"],"type":"string"},"edge_kind":{"description":"The relationship type to rank by (e.g. 'implements' to find most-implemented interfaces)","enum":["implements","extends","calls","uses","contains","annotates","derives_macro"],"type":"string"},"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"node_kind":{"description":"Optional filter for node kind (e.g. 'interface', 'class', 'trait', 'function', 'method')","type":"string"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}},"required":["edge_kind"]}},{"name":"mcp__tokensave__tokensave_recursion","description":"Detect recursive and mutually-recursive call cycles in the call graph.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of cycles to return (default: 10)","type":"number"},"path":{"description":"Filter to files under this directory path (e.g. 'src/main/java')","type":"string"}}}},{"name":"mcp__tokensave__tokensave_rename_preview","description":"Show all references to a symbol -- all edges where the node appears as source or target.","input_schema":{"type":"object","properties":{"node_id":{"description":"The unique node ID to find references for","type":"string"}},"required":["node_id"]}},{"name":"mcp__tokensave__tokensave_search","description":"Search for symbols (functions, structs, traits, etc.) in the code graph by name or keyword.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results to return (default: 10)","type":"number"},"query":{"description":"Search query string to match against symbol names","type":"string"}},"required":["query"]}},{"name":"mcp__tokensave__tokensave_session_end","description":"Re-scan and compare current health against session baseline (saved by session_start). Returns diff showing what improved or degraded.","input_schema":{"type":"object","properties":{}}},{"name":"mcp__tokensave__tokensave_session_start","description":"Save current health metrics as baseline for later comparison via session_end. Call this before starting work.","input_schema":{"type":"object","properties":{}}},{"name":"mcp__tokensave__tokensave_similar","description":"Find symbols with similar names using full-text search and substring matching.","input_schema":{"type":"object","properties":{"limit":{"description":"Maximum number of results (default: 10)","type":"number"},"symbol":{"description":"Symbol name to find similar matches for","type":"string"}},"required":["symbol"]}},{"name":"mcp__tokensave__tokensave_simplify_scan","description":"Quality analysis of changed files: duplications, dead code, coupling, and complexity hotspots.","input_schema":{"type":"object","properties":{"files":{"description":"Changed file paths to analyze","items":{"type":"string"},"type":"array"}},"required":["files"]}},{"name":"mcp__tokensave__tokensave_status","description":"Return aggregate statistics about the code graph (node/edge/file counts, DB size, etc.).","input_schema":{"type":"object","properties":{}}},{"name":"mcp__tokensave__tokensave_str_replace","description":"Replace a unique string in a file with new content. Fails if the old string is not found or matches more than once. This is the safest edit primitive — use this instead of sed/awk.","input_schema":{"type":"object","properties":{"new_str":{"description":"Replacement string","type":"string"},"old_str":{"description":"Exact string to find and replace. Must match exactly once in the file.","type":"string"},"path":{"description":"Absolute or project-relative file path","type":"string"}},"required":["path","old_str","new_str"]}},{"name":"mcp__tokensave__tokensave_test_map","description":"Map source symbols to their test functions. Shows which tests cover which source code.","input_schema":{"type":"object","properties":{"file":{"description":"Source file path to find test coverage for","type":"string"},"node_id":{"description":"Specific node ID to find test coverage for (alternative to file)","type":"string"}}}},{"name":"mcp__tokensave__tokensave_test_risk","description":"Find high-risk source symbols with weak or no test coverage. Risk = (complexity + 1) × (fan_in + 1) × untested_multiplier. Answers: where should the next test go?","input_schema":{"type":"object","properties":{"include_tested":{"description":"Include already-tested functions in results (default: false)","type":"boolean"},"limit":{"description":"Maximum number of results to return (default: 20)","type":"number"},"path":{"description":"Filter to files under this directory path","type":"string"}}}},{"name":"mcp__tokensave__tokensave_todos","description":"Find TODO, FIXME, XXX, HACK, WIP, NOTE, and unimplemented markers across the project. Each result includes the marker kind, file, line, the comment text, and the enclosing symbol name (function/method) for quick orientation.","input_schema":{"type":"object","properties":{"kinds":{"description":"Marker kinds to include (default: TODO, FIXME, XXX, HACK, WIP, NOTE, UNIMPLEMENTED). Matched case-insensitively.","items":{"type":"string"},"type":"array"},"limit":{"description":"Maximum number of markers to return (default: 200, max: 2000)","type":"number"},"path":{"description":"Filter to files under this directory path (relative to project root)","type":"string"}}}},{"name":"mcp__tokensave__tokensave_type_hierarchy","description":"Show the full type hierarchy for a trait/interface/class: all implementors and extenders, recursively.","input_schema":{"type":"object","properties":{"max_depth":{"description":"Maximum inheritance depth to traverse (default: 5)","type":"number"},"node_id":{"description":"The type node ID to build the hierarchy for","type":"string"}},"required":["node_id"]}},{"name":"mcp__tokensave__tokensave_unused_imports","description":"Find import/use nodes that are never referenced by any other node.","input_schema":{"type":"object","properties":{}}}],"metadata":{"user_id":"{\"device_id\":\"21f1df88ee8a1bb2f8de9e65eae77eeb94392037267bf16e60bf0be26db3f15a\",\"account_uuid\":\"\",\"session_id\":\"9b253bd4-d968-4b06-9cc9-fbba0908678f\"}"},"max_tokens":64000,"thinking":{"type":"adaptive"},"context_management":{"edits":[{"type":"clear_thinking_20251015","keep":"all"}]},"output_config":{"effort":"max"},"stream":true}


